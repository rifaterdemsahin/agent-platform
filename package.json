{
  "name": "agent-platform",
  "version": "1.0.0",
  "description": "Multi-agent platform — agents expose skills, code, and descriptions via API. LLM-powered background agents runnable from any project.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node tests/index.js",
    "test:sanity": "node -e \"import('./tests/sanity-check.test.js').then(m=>m.testSanityCheck())\"",
    "test:budget": "node -e \"import('./tests/budget.test.js').then(m=>m.testBudgetAgent())\"",
    "test:animation": "node -e \"import('./tests/animation.test.js').then(m=>m.testAnimationAgent())\"",
    "build:registry": "node scripts/build-registry.cjs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^4.72.0"
  }
}
